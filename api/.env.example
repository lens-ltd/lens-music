# App
NODE_ENV=development
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lens_music
DB_SSL=false

# JWT
JWT_SECRET=change_me
APP_URL=http://localhost:5173
# Optional; defaults to APP_URL + /logo.png for email templates
# LOGO_URL=https://your-cdn.example.com/logo.png

# Cloudinary (required for track audio sign/upload and release cover art)
# Dashboard: https://console.cloudinary.com → Settings → API Keys
# Without these, GET /tracks/:id/audio/sign and image/audio uploads return 500 "Cloudinary is not configured"
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Lens Music <no-reply@music.lens.rw>

# Invitation
INVITATION_EXPIRES_IN_DAYS=7

# Password reset
PASSWORD_RESET_EXPIRES_IN_MINUTES=60

# Admin
ADMIN_EMAIL=info@lens.rw
